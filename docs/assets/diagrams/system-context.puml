@startuml system-context
skinparam backgroundColor white
skinparam defaultFontName "SimSun"

rectangle "游客" as Guest
rectangle "普通用户" as User
rectangle "管理员" as Admin
rectangle "旅游管理系统前端" as Web
rectangle "后台管理页面" as AdminWeb
rectangle "后端接口" as API
database "MySQL 数据库" as DB

Guest --> Web
User --> Web
Admin --> AdminWeb
Web --> API
AdminWeb --> API
API --> DB
@enduml
